    "t-shirt": ["t-shirt", "tshirt", "kaos", "tee"],
    "jacket": ["jacket", "jaket", "outerwear", "coat"],
    "pants": ["pants", "trousers", "celana", "jeans"],
    "skirt": ["skirt", "rok"],
    "dress": ["dress", "gaun", "gown"],
    "hat": ["hat", "cap", "topi"]
  }
