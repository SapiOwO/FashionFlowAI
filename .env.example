# ==============================================================================
# SECRETS, CREDENTIALS & INFRASTRUCTURE TEMPLATE (.env.example)
# ==============================================================================
# Rename this file to `.env` and fill in your private parameters.

# --- DATABASE CONFIGURATION ---
# Options: "sqlite" (local file), "postgresql" (requires pgvector)
DB_TYPE=sqlite

# Connection settings (Only utilized if DB_TYPE is set to "postgresql")
# Host address of your PostgreSQL database
DB_HOST=127.0.0.1
# Port number of the database server (default: 5432)
DB_PORT=5432
# PostgreSQL database username
DB_USER=postgres
# Password for the database user
DB_PASS=
# Target database name for the project
DB_NAME=fashionflow_db
